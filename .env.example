# copy to .env and adjust

# Whisper model: tiny | base | small | medium | large-v3 | distil-large-v3
SCRIBE_MODEL=large-v3

# cuda or cpu
SCRIBE_DEVICE=cuda

# CTranslate2 compute type: int8_float16 fits large-v3 in ~4.5 GB VRAM
SCRIBE_COMPUTE=int8_float16

# Hugging Face token for speaker diarization (gated model).
# 1. https://huggingface.co/settings/tokens
# 2. accept conditions at https://huggingface.co/pyannote/speaker-diarization-community-1
# SCRIBE_HF_TOKEN=hf_...

# server bind
SCRIBE_HOST=127.0.0.1
SCRIBE_PORT=8323
